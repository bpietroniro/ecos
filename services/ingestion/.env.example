# Server
PORT=8080

# AWS
AWS_REGION=us-east-1

# DynamoDB (use endpoint override for local development)
DYNAMODB_ENDPOINT=http://localhost:8000
READINGS_TABLE_NAME=ecos-sensor-readings
STATIONS_TABLE_NAME=ecos-stations
READING_TYPE_INDEX_NAME=byReadingType

# SNS (leave empty for no-op publisher in local dev)
DATA_INGESTION_TOPIC_ARN=
ALERT_EVENTS_TOPIC_ARN=
SNS_ENDPOINT=
