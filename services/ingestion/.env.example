# Server
PORT=8080

# AWS
AWS_REGION=us-east-1

# DynamoDB (use endpoint override for local development)
DYNAMODB_ENDPOINT=http://localhost:8000
READINGS_TABLE_NAME=ecos-sensor-readings
STATIONS_TABLE_NAME=ecos-stations
READING_TYPE_INDEX_NAME=byReadingType

# SNS (leave empty for no-op publisher in local dev)
DATA_INGESTION_TOPIC_ARN=
ALERT_EVENTS_TOPIC_ARN=
SNS_ENDPOINT=

# Polling (disabled by default)
POLL_ENABLED=false
POLL_INTERVAL=5m

# NOAA (api.weather.gov — no API key needed)
NOAA_ENABLED=false
NOAA_STATION_IDS=KNYC,KJFK,KLAX
NOAA_USER_AGENT=(ecos-platform, contact@ecos.dev)

# OpenWeatherMap (requires API key)
OWM_ENABLED=false
OWM_API_KEY=
OWM_LOCATIONS=NYC:40.71,-74.00;LA:34.05,-118.24
